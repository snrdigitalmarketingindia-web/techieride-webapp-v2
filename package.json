{
  "name": "techieride-webapp-v2",
  "version": "2.1.0.772",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "start": "npm run build --workspace=packages/shared && npm run build --workspace=apps/api && npx prisma generate --schema=./prisma/schema.prisma && npx prisma db push --schema=./prisma/schema.prisma --accept-data-loss && node apps/api/dist/main",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:seed": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json prisma/seed.ts",
    "db:reset": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json prisma/reset-test-data.ts",
    "test:api": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test:api:extended": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-extended.ts",
    "test:api:negative": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-negative.ts",
    "test:api:rules": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-business-rules.ts",
    "test:api:coverage": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-coverage.ts",
    "test:api:final": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-final.ts",
    "test:api:final-a": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-final-a.ts",
    "test:api:final-b": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-final-b.ts",
    "test:api:final-b1": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-final-b1.ts",
    "test:api:final-b2": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-final-b2.ts",
    "test:all": "npm run test:api && npm run test:api:extended && npm run test:api:negative && npm run test:api:rules && npm run test:api:coverage && npm run test:api:final",
    "test:api:security": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-security.ts",
    "test:api:ratings-sos": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-ratings-sos.ts",
    "test:api:notifications": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-notifications.ts",
    "test:api:audit-trail": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-audit-trail.ts",
    "test:api:complaints": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-complaints.ts",
    "test:api:boarding": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-boarding.ts",
    "test:api:edge-cases": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-edge-cases.ts",
    "test:api:cancellation": "apps/api/node_modules/.bin/ts-node --project apps/api/tsconfig.json tests/e2e-api-cancellation.ts",
    "test:ui": "npx playwright test",
    "test:ui:security": "npx playwright test tests/e2e/security.spec.ts",
    "test:perf:smoke": "k6 run tests/performance/k6-smoke.js",
    "test:perf:load": "k6 run tests/performance/k6-load.js",
    "test:perf:stress": "k6 run tests/performance/k6-stress.js",
    "test:ci": "npm run test:all && npm run test:api:security && npm run test:api:ratings-sos && npm run test:api:notifications && npm run test:api:audit-trail && npm run test:api:complaints && npm run test:api:edge-cases && npm run test:api:cancellation",
    "lint:api": "npm run lint --workspace=apps/api",
    "version:stamp": "node -e \"const b=require('child_process').execSync('git rev-list --count HEAD').toString().trim(); const v=require('./package.json').version; const full=v+'.'+b; require('fs').writeFileSync('VERSION',full+'\\n'); console.log('Version stamped:',full);\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^8.2.2",
    "typescript": "5.3.3"
  },
  "dependencies": {
    "docker": "^1.0.0"
  }
}
