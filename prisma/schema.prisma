generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum AccountStatus {
  DRAFT
  EMAIL_VERIFICATION_PENDING    // registered, office email not yet verified
  PERSONAL_EMAIL_PENDING        // office email verified (or exception form submitted), personal email not yet verified
  DOCUMENT_VERIFICATION_PENDING // personal email verified, identity docs not yet submitted
  // TODO(phone-otp): PHONE_VERIFICATION_PENDING — insert between PERSONAL_EMAIL_PENDING and
  // DOCUMENT_VERIFICATION_PENDING once SMS OTP is enabled (cost-deferred).
  // Steps: POST /auth/send-phone-otp → PHONE_VERIFICATION_PENDING →
  //        POST /auth/verify-phone-otp → DOCUMENT_VERIFICATION_PENDING
  SEEKER_VERIFIED               // identity docs approved (IDENTITY type), TRID assigned, can book rides
  DRIVER_VERIFICATION_PENDING   // DL + RC submitted, awaiting admin
  DRIVER_VERIFIED               // driver docs approved, TRID assigned if not already, can offer rides
  SUSPENDED
  REJECTED
  DEACTIVATED
  BANNED
}

enum VerificationType {
  IDENTITY  // company ID + govt ID + self-declaration → SEEKER_VERIFIED + TRID
            // isException flag marks users who came via the office-email exception path
  DRIVER    // DL + RC → DRIVER_VERIFIED + TRID (assigned if not already seeker-verified)
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserRole {
  RIDE_GIVER
  RIDE_SEEKER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EcoLevel {
  SEED
  SPROUT
  LEAF
  TREE
  FOREST
}

enum RideStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  HOLD
  CONFIRMED
  COMPLETED
  REJECTED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  RIDE_APPROVED
  RIDE_REJECTED
  RIDE_CONFIRMED
  RIDE_STARTED
  RIDE_COMPLETED
  RIDE_CANCELLED
  REQUEST_APPROVED
  REQUEST_REJECTED
  HOLD_EXPIRING
  HOLD_EXPIRED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  SEEKER_BOARDED
  SEEKER_DEBOARDED
  SEEKER_NO_SHOW
  SOS_ALERT
  RATING_RECEIVED
  COMPLAINT_FILED
  QUICK_MESSAGE
  GENERIC
}

enum SosStatus {
  TRIGGERED
  ACKNOWLEDGED
  RESOLVED
}

enum ComplaintReason {
  HARASSMENT
  NO_SHOW
  UNSAFE_DRIVING
  FRAUD
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum EmailStatus {
  PENDING
  VERIFIED
  BOUNCED
}

enum PendingRegStatus {
  PERSONAL_EMAIL_SENT
  PERSONAL_EMAIL_VERIFIED
  OFFICE_EMAIL_SENT
  OFFICE_EMAIL_VERIFIED
  EXCEPTION_REQUESTED
  DOCS_UPLOADED
  PENDING_REVIEW
  REJECTED
  APPROVED
}

enum BoardingStatus {
  WAITING
  BOARDED
  DEBOARDED
  NO_SHOW
}

enum TrustBand {
  NEW
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id                        String             @id @default(uuid())
  email                     String             @unique    // official/company email — auth only
  personalEmail             String?                       // personal email — app notifications + login fallback
  personalEmailVerified     Boolean            @default(false)
  personalEmailToken        String?            @unique    // token sent to personal email for verification
  personalEmailExpiry       DateTime?
  passwordHash              String
  fullName                  String
  profilePhoto              String?
  gender                    Gender?
  companyName               String?
  employeeId                String?
  phone                     String?            @unique
  countryCode               String             @default("+91")
  isPhoneVerified           Boolean            @default(false)
  bloodGroup                String?                       // A+/A-/B+/B-/O+/O-/AB+/AB-
  homeLocation              String?                       // alias name e.g. "Home"
  homeLat                   Float?                        // pinned via Mapbox
  homeLng                   Float?
  homeAddress               String?                       // reverse-geocoded label
  officeLocation            String?                       // alias name e.g. "Office"
  officeLat                 Float?                        // pinned via Mapbox
  officeLng                 Float?
  officeAddress             String?                       // reverse-geocoded label
  trid                      String?            @unique    // TR2000, TR2001... assigned on approval
  role                      UserRole           @default(RIDE_SEEKER)
  verificationStatus        VerificationStatus @default(PENDING)
  emailStatus               EmailStatus        @default(PENDING)
  emailVerificationToken    String?            @unique
  emailVerificationExpiry   DateTime?
  tempPassword              String?                       // bcrypt hash of temp password (forgot-password flow)
  tempPasswordExpiry        DateTime?
  mustChangePassword        Boolean            @default(false)
  pendingEmail              String?                       // new email awaiting verification
  pendingEmailToken         String?            @unique    // token sent to new email
  pendingEmailExpiry        DateTime?
  isActive                  Boolean            @default(true)
  accountStatus             AccountStatus      @default(EMAIL_VERIFICATION_PENDING)
  verificationMethod        String?                       // EMAIL_VERIFIED | MANUAL_EXCEPTION
  fcmToken                  String?
  ecoPoints                 Int                @default(0)
  ecoLevel                  EcoLevel           @default(SEED)
  trustScore                Int                @default(10)
  trustBand                 TrustBand          @default(NEW)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  rideGiver            RideGiver?
  rideSeeker           RideSeeker?
  notifications        Notification[]
  gamificationPoints   GamificationPoint[]
  verificationRequests VerificationRequest[]
  emergencyContacts    EmergencyContact[]
  ratingsGiven         RideRating[]       @relation("rater")
  ratingsReceived      RideRating[]       @relation("ratee")
  sosEvents            SosEvent[]
  complaintsReported   Complaint[]        @relation("complaintsReported")
  complaintsReceived   Complaint[]        @relation("complaintsReceived")
  trustScoreEvents     TrustScoreEvent[]
  savedLocations       SavedLocation[]
  loginHistory         LoginHistory[]
  quickMessages        QuickMessage[]

  @@index([email])
  @@index([emailStatus])
  @@index([verificationStatus])
  @@map("users")
}


// ─── Pending Registration (staging table — account created only after admin approval) ──

model PendingRegistration {
  id                      String           @id @default(uuid())

  // Step 1: Personal email
  personalEmail           String           @unique
  personalEmailVerified   Boolean          @default(false)
  personalEmailToken      String?          @unique
  personalEmailExpiry     DateTime?

  // Step 2: Profile (filled after personal email verified)
  fullName                String?
  passwordHash            String?
  phone                   String?
  countryCode             String           @default("+91")
  companyName             String?
  gender                  Gender?
  bloodGroup              String?
  homeLocation            String?
  officeLocation          String?
  emergencyContactName    String?
  emergencyContactPhone   String?

  // Step 3: Office email
  officeEmail             String?
  officeEmailVerified     Boolean          @default(false)
  officeEmailToken        String?          @unique
  officeEmailExpiry       DateTime?

  // Exception path (can't verify office email)
  isException             Boolean          @default(false)
  exceptionReason         String?
  verificationMethod      String?          // EMAIL_VERIFIED | MANUAL_EXCEPTION

  // Step 4: Document uploads
  employeeIdUrl           String?          // Company ID card photo
  govtIdUrl               String?          // Aadhaar/PAN
  profilePhotoUrl         String?
  selfDeclarationAccepted Boolean          @default(false)

  // Admin review
  status                  PendingRegStatus @default(PERSONAL_EMAIL_SENT)
  rejectionReason         String?
  reviewedBy              String?
  reviewedAt              DateTime?

  // Lifecycle
  createdAt               DateTime         @default(now())
  expiresAt               DateTime

  @@index([status])
  @@index([expiresAt])
  @@map("pending_registrations")
}


model EmergencyContact {
  id           String @id @default(uuid())
  userId       String
  name         String
  phone        String
  relationship String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ─── Verification ─────────────────────────────────────────────────────────

model VerificationRequest {
  id                  String             @id @default(uuid())
  userId              String
  verificationType    VerificationType   @default(IDENTITY)
  employeeIdUrl           String?            // IDENTITY type — company ID card
  profilePhotoUrl         String?
  drivingLicenseUrl       String?            // DRIVER type
  rcUrl                   String?            // DRIVER type
  vehicleId               String?            // DRIVER type — linked vehicle submitted with application
  govtIdUrl               String?            // IDENTITY type — Aadhaar / PAN / Passport
  selfDeclarationAccepted Boolean            @default(false) // IDENTITY type
  exceptionReason         String?            // exception path only (isException = true)
  isException             Boolean            @default(false) // true = came via office-email exception
  status              VerificationStatus @default(PENDING)
  rejectionReason     String?
  reviewedBy          String?
  reviewedAt          DateTime?
  submittedAt         DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@unique([userId, verificationType])
  @@index([status])
  @@index([verificationType])
  @@map("verification_requests")
}

// ─── Ride Giver ────────────────────────────────────────────────────────────

model RideGiver {
  id                  String  @id @default(uuid())
  userId              String  @unique
  drivingLicenseUrl   String?
  licenseVerified     Boolean @default(false)
  totalRidesGiven     Int     @default(0)
  averageRating       Float   @default(0)
  preferredGender     String  @default("ANY")
  isAvailable         Boolean @default(true)
  createdAt           DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles         Vehicle[]
  rides            Ride[]
  commuteTemplates CommuteTemplate[]

  @@map("ride_givers")
}

// ─── Ride Seeker ──────────────────────────────────────────────────────────

model RideSeeker {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalRidesTaken Int      @default(0)
  averageRating   Float    @default(0)
  preferredGender String   @default("ANY")
  createdAt       DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rideRequests     RideRequest[]
  rideParticipants RideParticipant[]

  @@map("ride_seekers")
}

// ─── Vehicle ───────────────────────────────────────────────────────────────

model Vehicle {
  id           String   @id @default(uuid())
  rideGiverId  String
  make         String
  model        String
  year         Int?
  color        String?
  plateNumber  String   @unique
  rcUrl           String?
  rcVerified      Boolean  @default(false)
  rcMatchStatus   String?  // MATCHED (set when RC is successfully verified to match vehicle)
  rcParsedData    Json?    // raw fields extracted by Gemini from the RC image
  photoUrl        String?  // optional vehicle photo
  totalSeats      Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  rideGiver             RideGiver             @relation(fields: [rideGiverId], references: [id], onDelete: Cascade)
  rides                 Ride[]
  commuteTemplates      CommuteTemplate[]
  verificationRequests  VerificationRequest[]

  @@map("vehicles")
}

// ─── Commute Template ─────────────────────────────────────────────────────

model CommuteTemplate {
  id                String   @id @default(uuid())
  rideGiverId       String
  vehicleId         String
  originName        String
  originLat         Float
  originLng         Float
  destinationName   String
  destinationLat    Float
  destinationLng    Float
  departureDays     Int[]
  departureTime     String
  totalSeats        Int
  isActive          Boolean  @default(true)
  lastPublishedDate DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rideGiver RideGiver @relation(fields: [rideGiverId], references: [id], onDelete: Cascade)
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  rides     Ride[]

  @@index([rideGiverId])
  @@index([isActive])
  @@map("commute_templates")
}

// ─── Ride ─────────────────────────────────────────────────────────────────

model Ride {
  id                   String     @id @default(uuid())
  rideGiverId          String
  vehicleId            String
  templateId           String?
  originName           String
  originLat            Float
  originLng            Float
  destinationName      String
  destinationLat       Float
  destinationLng       Float
  routePolyline        Json?
  estimatedDistanceKm  Float?
  estimatedDurationMin Int?
  departureDate        DateTime
  departureTime        String
  estimatedArrivalTime String?
  totalSeats           Int
  availableSeats       Int
  womenOnly            Boolean    @default(false)
  status               RideStatus @default(DRAFT)
  notes                String?
  publishedAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  archivedAt           DateTime?  // set 4h after departure — hidden from active list, visible in history
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  rideGiver    RideGiver        @relation(fields: [rideGiverId], references: [id])
  vehicle      Vehicle          @relation(fields: [vehicleId], references: [id])
  template     CommuteTemplate? @relation(fields: [templateId], references: [id])
  requests     RideRequest[]
  participants RideParticipant[]
  ratings      RideRating[]
  sosEvents    SosEvent[]
  complaints    Complaint[]
  quickMessages QuickMessage[]

  @@index([rideGiverId])
  @@index([status])
  @@index([departureDate])
  @@index([originLat, originLng])
  @@map("rides")
}

// ─── Ride Request ─────────────────────────────────────────────────────────

model RideRequest {
  id             String        @id @default(uuid())
  rideId         String
  seekerId       String
  pickupLat      Float?
  pickupLng      Float?
  pickupName     String?
  pickupTime     String?       // "HH:MM" — set by giver at approval
  dropLat        Float?
  dropLng        Float?
  dropName       String?
  status         RequestStatus @default(PENDING)
  holdExpiresAt  DateTime?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  ride        Ride             @relation(fields: [rideId], references: [id], onDelete: Cascade)
  seeker      RideSeeker       @relation(fields: [seekerId], references: [id])
  participant RideParticipant?

  @@unique([rideId, seekerId])
  @@index([rideId])
  @@index([seekerId])
  @@index([status])
  @@map("ride_requests")
}

// ─── Ride Participant ─────────────────────────────────────────────────────

model RideParticipant {
  id             String         @id @default(uuid())
  rideId         String
  seekerId       String
  requestId      String         @unique
  pickupName     String?
  pickupTime     String?       // "HH:MM" — confirmed by giver at approval
  dropName       String?
  boardingStatus BoardingStatus @default(WAITING)
  boardedAt      DateTime?
  deboardedAt    DateTime?
  createdAt      DateTime       @default(now())

  ride    Ride        @relation(fields: [rideId], references: [id], onDelete: Cascade)
  seeker  RideSeeker  @relation(fields: [seekerId], references: [id])
  request RideRequest @relation(fields: [requestId], references: [id])

  @@unique([rideId, seekerId])
  @@map("ride_participants")
}

// ─── Ride Rating ──────────────────────────────────────────────────────────

model RideRating {
  id        String   @id @default(uuid())
  rideId    String
  raterId   String
  rateeId   String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  ride  Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  rater User @relation("rater", fields: [raterId], references: [id])
  ratee User @relation("ratee", fields: [rateeId], references: [id])

  @@unique([rideId, raterId, rateeId])
  @@map("ride_ratings")
}

// ─── Notification ─────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Gamification ─────────────────────────────────────────────────────────

model GamificationPoint {
  id         String   @id @default(uuid())
  userId     String
  eventType  String
  points     Int
  rideId     String?
  co2SavedG  Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("gamification_points")
}

// ─── Trust Score ──────────────────────────────────────────────────────────

model TrustScoreEvent {
  id          String   @id @default(uuid())
  userId      String
  delta       Int                         // positive or negative
  eventType   String                      // RIDE_COMPLETED_GIVER, NO_SHOW, COMPLAINT, etc.
  reason      String?                     // human-readable note
  referenceId String?                     // rideId, complaintId, etc. for idempotency
  scoreAfter  Int                         // score snapshot after this event
  adminId     String?                     // set when admin manually adjusts
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType, referenceId])  // idempotency guard
  @@index([userId])
  @@index([createdAt])
  @@map("trust_score_events")
}

// ─── Call Log (audit) ─────────────────────────────────────────────────────

model CallLog {
  id         String   @id @default(uuid())
  callerId   String
  receiverId String
  rideId     String?
  event      String   @default("USER_CALL_INITIATED")
  createdAt  DateTime @default(now())

  @@index([callerId])
  @@index([receiverId])
  @@index([rideId])
  @@map("call_logs")
}

// ─── Complaint ────────────────────────────────────────────────────────────

model Complaint {
  id          String          @id @default(uuid())
  reporterId  String
  reportedId  String
  rideId      String?
  reason      ComplaintReason
  description String?
  status      ComplaintStatus @default(OPEN)
  adminNotes  String?
  resolvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  resolvedAt  DateTime?

  reporter User  @relation("complaintsReported", fields: [reporterId], references: [id])
  reported User  @relation("complaintsReceived", fields: [reportedId], references: [id])
  ride     Ride? @relation(fields: [rideId], references: [id])

  @@index([status])
  @@index([reportedId])
  @@map("complaints")
}

// ─── Audit Log ────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actor      String                        // userId or "SYSTEM"
  actorType  String   @default("USER")     // USER | SYSTEM | ADMIN
  action     String                        // RIDE_CANCELLED, CALL_INITIATED, etc.
  entityType String                        // ride | request | user | call | etc.
  entityId   String?                       // the affected record id
  metadata   Json?                         // extra context (reason, old/new values, etc.)
  createdAt  DateTime @default(now())

  @@index([actor])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── SOS Event ────────────────────────────────────────────────────────────

model SosEvent {
  id          String    @id @default(uuid())
  userId      String
  rideId      String?
  lat         Float
  lng         Float
  status      SosStatus @default(TRIGGERED)
  resolvedBy  String?
  resolutionNotes String?
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?

  user User  @relation(fields: [userId], references: [id])
  ride Ride? @relation(fields: [rideId], references: [id])

  @@index([status])
  @@map("sos_events")
}

// ─── Saved Locations (Aliases) ────────────────────────────────────────────────
// Ride seekers can save up to 20 frequently used pickup/drop locations with a
// custom alias (e.g. "Home", "Gym", "HITEC City Office") so they don't have to
// re-pin every time they request a ride.

// ─── Quick Message Log ────────────────────────────────────────────────────────
// Persists every quick-message send for admin audit / 360° view.
// Historical messages (before this model was added) are not backfilled.

model QuickMessage {
  id          String   @id @default(uuid())
  rideId      String
  senderId    String
  messageKey  String                          // e.g. "ON_MY_WAY" or "CUSTOM"
  messageText String                          // resolved text at send time
  sentAt      DateTime @default(now())

  ride   Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id])

  @@index([rideId])
  @@index([senderId])
  @@map("quick_messages")
}

model SavedLocation {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  alias      String                        // display name e.g. "Home", "Gym"
  lat        Float
  lng        Float
  address    String    @default("")        // reverse-geocoded label
  isFavorite Boolean   @default(false)
  sourceType String    @default("SEARCH") // "SEARCH" | "PIN"
  usageCount Int       @default(0)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("saved_locations")
}

// ─── Login History ────────────────────────────────────────────────────────────

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

// ─── System Config ────────────────────────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_config")
}
