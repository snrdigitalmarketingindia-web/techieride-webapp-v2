generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum AccountStatus {
  DRAFT
  EMAIL_VERIFICATION_PENDING
  EXCEPTION_VERIFICATION_REQUESTED
  DOCUMENT_VERIFICATION_PENDING
  EMPLOYEE_VERIFIED
  DRIVER_VERIFICATION_PENDING
  DRIVER_VERIFIED
  SUSPENDED
  REJECTED
  DEACTIVATED
  BANNED
}

enum VerificationType {
  EMPLOYEE
  DRIVER
  EXCEPTION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum UserRole {
  RIDE_GIVER
  RIDE_SEEKER
  BOTH
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EcoLevel {
  SEED
  SPROUT
  LEAF
  TREE
  FOREST
}

enum RideStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  HOLD
  CONFIRMED
  REJECTED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  RIDE_APPROVED
  RIDE_REJECTED
  RIDE_CONFIRMED
  RIDE_STARTED
  RIDE_COMPLETED
  RIDE_CANCELLED
  REQUEST_APPROVED
  REQUEST_REJECTED
  HOLD_EXPIRING
  HOLD_EXPIRED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  SEEKER_BOARDED
  SEEKER_DEBOARDED
  SEEKER_NO_SHOW
  SOS_ALERT
  GENERIC
}

enum SosStatus {
  TRIGGERED
  ACKNOWLEDGED
  RESOLVED
}

enum ComplaintReason {
  HARASSMENT
  NO_SHOW
  UNSAFE_DRIVING
  FRAUD
  INAPPROPRIATE_CONTENT
  OTHER
}

enum ComplaintStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum EmailStatus {
  PENDING
  VERIFIED
  BOUNCED
}

enum BoardingStatus {
  WAITING
  BOARDED
  DEBOARDED
  NO_SHOW
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id                        String             @id @default(uuid())
  email                     String             @unique    // official/company email — auth only
  personalEmail             String?                       // personal email — app notifications
  passwordHash              String
  fullName                  String
  profilePhoto              String?
  gender                    Gender?
  companyName               String?
  employeeId                String?
  phone                     String?            @unique
  countryCode               String             @default("+91")
  isPhoneVerified           Boolean            @default(false)
  bloodGroup                String?                       // A+/A-/B+/B-/O+/O-/AB+/AB-
  homeLocation              String?                       // text description max 15 words
  officeLocation            String?                       // text description max 15 words
  trid                      String?            @unique    // TR2000, TR2001... assigned on approval
  role                      UserRole           @default(RIDE_SEEKER)
  verificationStatus        VerificationStatus @default(PENDING)
  emailStatus               EmailStatus        @default(PENDING)
  emailVerificationToken    String?            @unique
  emailVerificationExpiry   DateTime?
  passwordResetToken        String?            @unique
  passwordResetExpiry       DateTime?
  pendingEmail              String?                       // new email awaiting verification
  pendingEmailToken         String?            @unique    // token sent to new email
  pendingEmailExpiry        DateTime?
  isActive                  Boolean            @default(true)
  accountStatus             AccountStatus      @default(EMAIL_VERIFICATION_PENDING)
  verificationMethod        String?                       // EMAIL_VERIFIED | MANUAL_EXCEPTION
  fcmToken                  String?
  ecoPoints                 Int                @default(0)
  ecoLevel                  EcoLevel           @default(SEED)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  rideGiver            RideGiver?
  rideSeeker           RideSeeker?
  notifications        Notification[]
  gamificationPoints   GamificationPoint[]
  verificationRequests VerificationRequest[]
  emergencyContacts    EmergencyContact[]
  ratingsGiven         RideRating[]       @relation("rater")
  ratingsReceived      RideRating[]       @relation("ratee")
  sosEvents            SosEvent[]
  complaintsReported   Complaint[]        @relation("complaintsReported")
  complaintsReceived   Complaint[]        @relation("complaintsReceived")

  @@index([email])
  @@index([emailStatus])
  @@index([verificationStatus])
  @@map("users")
}


model EmergencyContact {
  id           String @id @default(uuid())
  userId       String
  name         String
  phone        String
  relationship String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ─── Verification ─────────────────────────────────────────────────────────

model VerificationRequest {
  id                  String             @id @default(uuid())
  userId              String
  verificationType    VerificationType   @default(EMPLOYEE)
  employeeIdUrl       String?
  profilePhotoUrl     String?
  drivingLicenseUrl   String?
  rcUrl               String?
  exceptionReason     String?            // filled for EXCEPTION type
  status              VerificationStatus @default(PENDING)
  rejectionReason     String?
  reviewedBy          String?
  reviewedAt          DateTime?
  submittedAt         DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, verificationType])
  @@index([status])
  @@index([verificationType])
  @@map("verification_requests")
}

// ─── Ride Giver ────────────────────────────────────────────────────────────

model RideGiver {
  id                  String  @id @default(uuid())
  userId              String  @unique
  drivingLicenseUrl   String?
  licenseVerified     Boolean @default(false)
  totalRidesGiven     Int     @default(0)
  averageRating       Float   @default(0)
  preferredGender     String  @default("ANY")
  isAvailable         Boolean @default(true)
  createdAt           DateTime @default(now())

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles         Vehicle[]
  rides            Ride[]
  commuteTemplates CommuteTemplate[]

  @@map("ride_givers")
}

// ─── Ride Seeker ──────────────────────────────────────────────────────────

model RideSeeker {
  id              String   @id @default(uuid())
  userId          String   @unique
  totalRidesTaken Int      @default(0)
  averageRating   Float    @default(0)
  preferredGender String   @default("ANY")
  createdAt       DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rideRequests     RideRequest[]
  rideParticipants RideParticipant[]

  @@map("ride_seekers")
}

// ─── Vehicle ───────────────────────────────────────────────────────────────

model Vehicle {
  id           String   @id @default(uuid())
  rideGiverId  String
  make         String
  model        String
  year         Int?
  color        String?
  plateNumber  String   @unique
  rcUrl        String?
  rcVerified   Boolean  @default(false)
  totalSeats   Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  rideGiver        RideGiver         @relation(fields: [rideGiverId], references: [id], onDelete: Cascade)
  rides            Ride[]
  commuteTemplates CommuteTemplate[]

  @@map("vehicles")
}

// ─── Commute Template ─────────────────────────────────────────────────────

model CommuteTemplate {
  id                String   @id @default(uuid())
  rideGiverId       String
  vehicleId         String
  originName        String
  originLat         Float
  originLng         Float
  destinationName   String
  destinationLat    Float
  destinationLng    Float
  departureDays     Int[]
  departureTime     String
  totalSeats        Int
  isActive          Boolean  @default(true)
  lastPublishedDate DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  rideGiver RideGiver @relation(fields: [rideGiverId], references: [id], onDelete: Cascade)
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  rides     Ride[]

  @@index([rideGiverId])
  @@index([isActive])
  @@map("commute_templates")
}

// ─── Ride ─────────────────────────────────────────────────────────────────

model Ride {
  id                   String     @id @default(uuid())
  rideGiverId          String
  vehicleId            String
  templateId           String?
  originName           String
  originLat            Float
  originLng            Float
  destinationName      String
  destinationLat       Float
  destinationLng       Float
  routePolyline        Json?
  estimatedDistanceKm  Float?
  estimatedDurationMin Int?
  departureDate        DateTime
  departureTime        String
  estimatedArrivalTime String?
  totalSeats           Int
  availableSeats       Int
  status               RideStatus @default(DRAFT)
  notes                String?
  startedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  rideGiver    RideGiver        @relation(fields: [rideGiverId], references: [id])
  vehicle      Vehicle          @relation(fields: [vehicleId], references: [id])
  template     CommuteTemplate? @relation(fields: [templateId], references: [id])
  requests     RideRequest[]
  participants RideParticipant[]
  ratings      RideRating[]
  sosEvents    SosEvent[]
  complaints   Complaint[]

  @@index([rideGiverId])
  @@index([status])
  @@index([departureDate])
  @@index([originLat, originLng])
  @@map("rides")
}

// ─── Ride Request ─────────────────────────────────────────────────────────

model RideRequest {
  id             String        @id @default(uuid())
  rideId         String
  seekerId       String
  pickupLat      Float?
  pickupLng      Float?
  pickupName     String?
  dropLat        Float?
  dropLng        Float?
  dropName       String?
  status         RequestStatus @default(PENDING)
  holdExpiresAt  DateTime?
  confirmedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  ride        Ride             @relation(fields: [rideId], references: [id], onDelete: Cascade)
  seeker      RideSeeker       @relation(fields: [seekerId], references: [id])
  participant RideParticipant?

  @@unique([rideId, seekerId])
  @@index([rideId])
  @@index([seekerId])
  @@index([status])
  @@map("ride_requests")
}

// ─── Ride Participant ─────────────────────────────────────────────────────

model RideParticipant {
  id             String         @id @default(uuid())
  rideId         String
  seekerId       String
  requestId      String         @unique
  pickupName     String?
  dropName       String?
  boardingStatus BoardingStatus @default(WAITING)
  boardedAt      DateTime?
  deboaredAt     DateTime?
  createdAt      DateTime       @default(now())

  ride    Ride        @relation(fields: [rideId], references: [id], onDelete: Cascade)
  seeker  RideSeeker  @relation(fields: [seekerId], references: [id])
  request RideRequest @relation(fields: [requestId], references: [id])

  @@unique([rideId, seekerId])
  @@map("ride_participants")
}

// ─── Ride Rating ──────────────────────────────────────────────────────────

model RideRating {
  id        String   @id @default(uuid())
  rideId    String
  raterId   String
  rateeId   String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  ride  Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  rater User @relation("rater", fields: [raterId], references: [id])
  ratee User @relation("ratee", fields: [rateeId], references: [id])

  @@unique([rideId, raterId, rateeId])
  @@map("ride_ratings")
}

// ─── Notification ─────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── Gamification ─────────────────────────────────────────────────────────

model GamificationPoint {
  id         String   @id @default(uuid())
  userId     String
  eventType  String
  points     Int
  rideId     String?
  co2SavedG  Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("gamification_points")
}

// ─── Call Log (audit) ─────────────────────────────────────────────────────

model CallLog {
  id         String   @id @default(uuid())
  callerId   String
  receiverId String
  rideId     String?
  event      String   @default("USER_CALL_INITIATED")
  createdAt  DateTime @default(now())

  @@index([callerId])
  @@index([receiverId])
  @@index([rideId])
  @@map("call_logs")
}

// ─── Complaint ────────────────────────────────────────────────────────────

model Complaint {
  id          String          @id @default(uuid())
  reporterId  String
  reportedId  String
  rideId      String?
  reason      ComplaintReason
  description String?
  status      ComplaintStatus @default(OPEN)
  adminNotes  String?
  resolvedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  resolvedAt  DateTime?

  reporter User  @relation("complaintsReported", fields: [reporterId], references: [id])
  reported User  @relation("complaintsReceived", fields: [reportedId], references: [id])
  ride     Ride? @relation(fields: [rideId], references: [id])

  @@index([status])
  @@index([reportedId])
  @@map("complaints")
}

// ─── SOS Event ────────────────────────────────────────────────────────────

model SosEvent {
  id          String    @id @default(uuid())
  userId      String
  rideId      String?
  lat         Float
  lng         Float
  status      SosStatus @default(TRIGGERED)
  resolvedBy  String?
  resolutionNotes String?
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?

  user User  @relation(fields: [userId], references: [id])
  ride Ride? @relation(fields: [rideId], references: [id])

  @@index([status])
  @@map("sos_events")
}
