# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
RENDER_EXTERNAL_URL=https://techieride-webapp-v2.onrender.com

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://techieride:techieride@localhost:5432/techieride

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DOCUMENTS=user-documents
MINIO_BUCKET_PHOTOS=profile-photos

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@techieride.in
RESEND_WEBHOOK_SECRET=
CONTACTS_EMAIL=hydtechieride@gmail.com
APP_URL=http://localhost:3000

# ─── Gemini AI (RC document parsing) ──────────────────
# Get free key from https://aistudio.google.com — no credit card needed
# Free tier: 1,500 RC parses/day, 15/min — sufficient for production use
GEMINI_API_KEY=

# ─── Firebase FCM ──────────────────────────────────────
FCM_SERVER_KEY=

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ─── Maps (set ONE of these — Mappls is recommended for India/Hyderabad) ──────
# Mappls (MapMyIndia) — best India coverage, free key from https://maps.olakrutrim.com
# Sign up → Create App → copy the Static Key
NEXT_PUBLIC_MAPPLS_KEY=

# Ola Maps (Krutrim) — also India-optimised, get key from https://maps.olakrutrim.com
NEXT_PUBLIC_OLA_MAPS_API_KEY=

# If neither key is set, falls back to OpenStreetMap raster tiles (no key needed)

# ─── Feature flags ──────────────────────────────────────
# Attendance (Boarded/Deboarded/No-Show) — parked, off by default.
# Set BOTH when enabling: backend gate + frontend UI.
FEATURE_ATTENDANCE_TRACKING=false
NEXT_PUBLIC_FEATURE_ATTENDANCE_TRACKING=false
# Interactive maps (pin pickers, route maps, live tracking). On by default.
# When false, location pickers fall back to address search (no map tiles).
NEXT_PUBLIC_FEATURE_MAPS=true
